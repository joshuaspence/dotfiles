---
data:
  goreleaser:
    arch: '{{ .chezmoi.arch | replace "amd64" "x86_64" }}'
    os: '{{ .chezmoi.os | title }}'
  headless: {{ env "GITHUB_ACTIONS" | empty | not }}
  personal: {{ promptBoolOnce . "personal" "Enable personal profile" false }}
  sudo: '{{ if ne .chezmoi.username "root" -}} sudo {{ end }}'
  work: {{ promptBoolOnce . "work" "Enable work profile" false }}
github:
  refreshPeriod: '12h'
textconv:
  - pattern: '**/*.json'
    command: 'jq'
    args:
      - '--sort-keys'
      - '.'
  - pattern: '**/*.yaml'
    command: 'yq'
    args:
      - 'sort_keys(..)'
