{{- $config := dict
  "$schema" "https://json.schemastore.org/claude-code-settings.json"
  "autoMode" (dict
    "environment" (list "$defaults")
    "allow" (list "$defaults")
    "soft_deny" (list "$defaults")
  )
  "defaultMode" "auto"
  "editorMode" "default"
  "enabledPlugins" (dict
    "alfredo@anduril-claude-clams" true
    "anduril-developer-docs@anduril-claude-clams" true
    "anduril-voice@anduril-claude-clams" true
    "atlassian@claude-plugins-official" true
    "atlassian-mcp@anduril-claude-clams" true
    "circleci@anduril-claude-clams" true
    "circleci-debug@anduril-claude-clams" true
    "circleci-toolkit@anduril-claude-clams" true
    "circleci-troubleshooter@anduril-claude-clams" true
    "claude-code-setup@claude-plugins-official" true
    "claude-md-management@claude-plugins-official" true
    "claudit@anduril-claude-clams" true
    "code-review@claude-plugins-official" true
    "code-simplifier@claude-plugins-official" true
    "document-skills@anthropic-agent-skills" true
    "explanatory-output-style@claude-plugins-official" true
    "hookify@claude-plugins-official" true
    "jira-cli@anduril-claude-clams" true
    "outlook-calendar@anduril-claude-clams" true
    "outlook-email@anduril-claude-clams" true
    "pptx-generator@anduril-claude-clams" true
    "ralph-loop@claude-plugins-official" true
    "remember@claude-plugins-official" true
    "self-improvement@anduril-claude-clams" true
    "skill-creator@claude-plugins-official" true
    "slack@claude-plugins-official" true
    "superpowers@claude-plugins-official" true
    "terraform@claude-plugins-official" true
  )
  "env" (dict
    "CLAUDE_CODE_NEW_INIT" "true"
    "DISABLE_UPDATES" true
  )
  "extraKnownMarketplaces" (dict
    "anthropic-agent-skills" (dict
      "source" (dict
        "source" "git"
        "url" "https://github.com/anthropics/skills.git"
      )
    )
  )
  "model" "opusplan"
  "permissions" (dict
    "allow" (list 
      "Bash(jq:*)"
      "Read(~/workspace)"
    )
    "deny" (list 
      "Read(./.env)"
    )
    "ask" (list)
  )
  "sandbox" (dict
    "enabled" true
    "excludedCommands" (list)
    "failIfUnavailable" true
    "filesystem" (dict
      "allowWrite" (list "/tmp")
    )
    "network" (dict
      "allowedDomains" (list
        "api.github.com"
        "docs.aws.amazon.com"
        "docs.kernel.org"
        "github.com"
        "manpages.ubuntu.com"
        "man7.org"
        "raw.githubusercontent.com"
        "*.readthedocs.io"
        "serverfault.com"
        "stackoverflow.com"
        "superuser.com"
        "systemd.io"
      )
      "allowAllUnixSockets" true
    )
  )
  "statusLine" (dict
    "type" "command"
    "command" "bash ~/.config/claude/statusline.sh"
  )
  "tui" "fullscreen"
-}}

{{- if .personal -}}
{{- $config = merge $config (dict
  "permissions" (dict
    "allow" (list
      "Read(~/Dropbox/Documents/Personal/Invoices/**/*.pdf)"
    )
  )
) -}}
{{- end -}}

{{- if .work -}}
{{- $config = merge $config (dict
  "awsAuthRefresh" "aws sso login --sso-session anduril-govcom"
  "env" (dict
    "AWS_PROFILE" "claude"
    "AWS_REGION" "ap-southeast-2"
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC" "true"
    "CLAUDE_CODE_USE_BEDROCK" "true"
  )
  "extraKnownMarketplaces" (dict
    "anduril" (dict
      "source" (dict
        "source" "git"
        "url" "https://ghe.anduril.dev/anduril/claude-clams.git"
      )
    )
  )
  "skipWebFetchPreflight" true
) -}}
{{- end -}}

{{ $config | toPrettyJson }}
