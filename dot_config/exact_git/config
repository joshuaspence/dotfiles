[advice]
statusHints = false

[alias]
aliases = "!git config --get-regexp '^alias\\.' | sed 's/^alias\\.//; s/ / = /' | sort"
amend = commit --no-edit --amend
branches = branch --all
cleanup = !git remote prune origin && git gc --aggressive --auto
empty-blob = hash-object -t blob /dev/null
empty-tree = hash-object -t tree /dev/null
initial-commit = rev-list --max-parents=0 HEAD
remotes = remote --verbose
reword = commit --amend
root = rev-parse --show-toplevel
tags = tag --list
untrack = rm --cached

# List the files that have changed.
changed = diff --name-only

# Ignore changes to a tracked file.
ignore-changes = update-index --assume-unchanged
unignore-changes = update-index --no-assume-unchanged

# List files that are not under version control.
ls-ignored = ls-files --exclude-standard --ignored --others

# List all repositories in my workspace.
workspace = "!find ~/workspace -type d -exec sh -c 'git -C {} rev-parse --git-dir >/dev/null 2>&1' \\; -prune -print | sort"

[apply]
whitespace = fix

[blame]
coloring = highlightRecent
date = human
ignoreRevsFile = .git-blame-ignore-revs

[branch]
autoSetupRebase = always

[checkout]
workers = 0

[clean]
requireForce = false

[clone]
filterSubmodules = true

[color "blame"]
highlightRecent = #ffff00,1 year ago,#ffcc00,3 month ago,#ff9900,1 month ago,#ff6600,1 week ago,#ff3300,1 day ago,#ff0000

[color "diff"]
meta = yellow bold

[color "grep"]
filename = yellow bold

[color "status"]
changed = yellow
untracked = cyan

[core]
autocrlf = input
commentChar = auto
untrackedCache = true

[credential]
helper = cache

[credential "https://github.com"]
helper =
helper = !gh auth git-credential

[diff]
algorithm = histogram
colorMoved = default
noprefix = true
renames = copy
submodule = diff
suppressBlankEmpty = true

[difftool]
guiDefault = auto

[fetch]
parallel = 0
prune = true
pruneTags = true

[filter "lfs"]
clean = git-lfs clean -- %f
process = git-lfs filter-process
required = true
smudge = git-lfs smudge -- %f

[format]
pretty = fuller

[grep]
lineNumber = true

[help]
autoCorrect = 10

[init]
defaultBranch = master

[log]
date = local
follow = true

[merge]
guitool = meld
tool = vimdiff

[mergetool]
guiDefault = auto
hideResolved = true
keepBackup = false

[pager]
branch = false

[pull]
rebase = true

[push]
autoSetupRemote = true
default = upstream

[rebase]
autoSquash = true

[rerere]
autoUpdate = true
enabled = true

[status]
showStash = true
showUntrackedFiles = all

[submodule]
fetchJobs = 0

[tag]
sort = version:refname

[url "git@github.com:"]
insteadOf = github:

[url "ssh://git@ghe.anduril.au/"]
insteadOf = https://ghe.anduril.au/

[url "ssh://git@ghe.anduril.dev/"]
insteadOf = https://ghe.anduril.dev/

[user]
email = josh@spence.com.au
name = Josh Spence
useConfigOnly = true

[includeIf "gitdir:~/workspace/ghe.anduril.*/"]
path = work.config

[includeIf "hasconfig:remote.*.url:git@ghe.anduril.*/**"]
path = work.config
