[advice]
statusHints = false

[alias]
aliases = "!git config --get-regexp '^alias\\.' | sed 's/^alias\\.//; s/ / = /' | sort"
amend = commit --no-edit --amend
branches = branch --all
cleanup = !git remote prune origin && git gc --aggressive --auto
empty-blob = hash-object -t blob /dev/null
empty-tree = hash-object -t tree /dev/null
initial-commit = rev-list --max-parents=0 HEAD
remotes = remote --verbose
reword = commit --amend
root = rev-parse --show-toplevel
tags = tag --list
untrack = rm --cache

# List the files that have changed.
changed = diff --name-only

# Ignore changes to a tracked file.
ignore-changes = update-index --assume-unchanged
unignore-changes = update-index --no-assume-unchanged

# List files that are not under version control.
ls-ignored = ls-files --exclude-standard --ignored --others

# List all repositories in my workspace.
workspace = "!find ~/workspace -type d -exec sh -c 'git -C {} rev-parse --git-dir >/dev/null 2>&1' \\; -prune -print | sort"

[apply]
whitespace = fix

[branch]
autoSetupRebase = always

[clean]
requireForce = false

[color "diff"]
meta = yellow bold

[color "grep"]
filename = yellow bold

[color "status"]
changed = yellow
untracked = cyan

[core]
autocrlf = input
untrackedCache = true

[credential "https://github.com"]
helper =
helper = !gh auth git-credential

[diff]
algorithm = histogram
noprefix = true
renames = copy

[fetch]
prune = true
pruneTags = true

[filter "lfs"]
clean = git-lfs clean -- %f
process = git-lfs filter-process
required = true
smudge = git-lfs smudge -- %f

[format]
pretty = fuller

[help]
autoCorrect = 10

[log]
date = local
follow = true

[merge]
guitool = meld
tool = vimdiff

[mergetool]
guiDefault = auto
keepBackup = false

[pager]
branch = false

[pull]
rebase = true

[push]
default = upstream

[rebase]
autoSquash = true

[rerere]
autoUpdate = true
enabled = true

[status]
showStash = true
showUntrackedFiles = all

[url "git@github.com:"]
insteadOf = github:

[url "ssh://git@ghe.anduril.au/"]
insteadOf = https://ghe.anduril.au/

[url "ssh://git@ghe.anduril.dev/"]
insteadOf = https://ghe.anduril.dev/

[user]
name = Josh Spence
email = josh@spence.com.au

[includeIf "gitdir:~/workspace/ghe.anduril.*/"]
path = work.config

[includeIf "hasconfig:remote.*.url:git@ghe.anduril.*/**"]
path = work.config
