#!/bin/bash
# shellcheck shell=bash

set -o errexit
set -o nounset
set -o pipefail

{{ $sourceDir := .chezmoi.sourceDir -}}
{{ range $file := glob (joinPath $sourceDir "ansible/*.yaml") -}}
# {{ trimPrefix (print $sourceDir "/") $file }}: {{ include $file | sha256sum }}
{{ end }}
if ! command -v ansible-playbook >/dev/null; then
  python3 -c 'import ensurepip' 2>/dev/null || {{ if ne .chezmoi.username "root" -}} sudo {{ end -}} apt-get install --no-install-recommends --yes python3-venv
  python3 -m venv /tmp/venv
  source /tmp/venv/bin/activate
  pip install --constraint <(chezmoi execute-template <{{ $sourceDir }}/dot_venv/requirements.in.tmpl) ansible github3.py python-debian
fi

ansible-playbook {{ if ne .chezmoi.username "root" -}} --ask-become-pass {{ end -}} {{ joinPath $sourceDir "ansible/site.yaml" }}
