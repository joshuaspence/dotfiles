#!{{ if ne .chezmoi.username "root" -}} {{ lookPath "sudo" }} {{ end -}} .local/bin/aptfile
# shellcheck shell=bash

source {{ joinPath .chezmoi.sourceDir "src/aptfile.bash" }}

# Repositories
{{ if .work -}}
apt_repository "1password" "https://downloads.1password.com/{{ .chezmoi.os }}/{{ .chezmoi.osRelease.idLike }}/{{ .chezmoi.arch }}" "stable main" "{{ .chezmoi.arch }}" "https://downloads.1password.com/{{ .chezmoi.os }}/keys/1password.asc"
apt_repository "cloudflare" "https://pkg.cloudflareclient.com" "{{ .chezmoi.osRelease.ubuntuCodename }} main" "{{ .chezmoi.arch }}" "https://pkg.cloudflareclient.com/pubkey.gpg"
{{ end -}}
apt_repository "docker" "https://download.docker.com/{{ .chezmoi.os }}/{{ .chezmoi.osRelease.id }}" "{{ .chezmoi.osRelease.ubuntuCodename }} stable" "{{ .chezmoi.arch }}" "https://download.docker.com/{{ .chezmoi.os }}/{{ .chezmoi.osRelease.id }}/gpg"
{{ if .personal -}}
apt_repository "dropbox" "https://linux.dropbox.com/ubuntu" "{{ .chezmoi.osRelease.ubuntuCodename }} main" "" "https://linux.dropbox.com/fedora/rpm-public-key.asc"
{{ end -}}
apt_repository "github_cli" "https://cli.github.com/packages" "stable main" "" "https://cli.github.com/packages/githubcli-archive-keyring.gpg"
apt_repository "hashicorp" "https://apt.releases.hashicorp.com" "{{ .chezmoi.osRelease.ubuntuCodename }} main" "{{ .chezmoi.arch }}" "https://apt.releases.hashicorp.com/gpg"
apt_repository "helm" "https://packages.buildkite.com/helm-{{ .chezmoi.os }}/helm-{{ .chezmoi.osRelease.idLike }}/any/" "any main" "" "https://packages.buildkite.com/helm-{{ .chezmoi.os }}/helm-{{ .chezmoi.osRelease.idLike }}/gpgkey"
{{ if .work -}}
apt_repository "jfrog" "https://releases.jfrog.io/artifactory/jfrog-debs" "{{ .chezmoi.osRelease.ubuntuCodename }} contrib" "" "https://releases.jfrog.io/artifactory/jfrog-gpg-public/jfrog_public_gpg.key"
{{- end }}
apt_repository "kubernetes" "https://pkgs.k8s.io/core:/stable:/v1.35/deb/" "/" "" "https://pkgs.k8s.io/core:/stable:/v1.35/deb/Release.key"
{{ if .work -}}
apt_repository "slack" "https://packagecloud.io/slacktechnologies/slack/{{ .chezmoi.osRelease.idLike }}" "jessie main" "" "https://packagecloud.io/slacktechnologies/slack/gpgkey"
{{- end }}
apt_repository "speedtest" "https://packagecloud.io/ookla/speedtest-cli/{{ .chezmoi.osRelease.id }}" "{{ .chezmoi.osRelease.ubuntuCodename | replace "noble" "jammy" }} main" "" "https://packagecloud.io/ookla/speedtest-cli/gpgkey"
apt_repository "task" "https://dl.cloudsmith.io/public/task/task/deb/{{ .chezmoi.osRelease.id }}" "{{ .chezmoi.osRelease.ubuntuCodename }} main" "" "https://dl.cloudsmith.io/public/task/task/gpg.key"
{{ if .work -}}
apt_repository "teleport" "https://apt.releases.teleport.dev/{{ .chezmoi.osRelease.id }}" "{{ .chezmoi.osRelease.ubuntuCodename }} stable/v15" "" "https://apt.releases.teleport.dev/gpg"
{{- end }}
apt_repository "vscode" "https://packages.microsoft.com/repos/code" "stable main" "amd64,arm64,armhf" "https://packages.microsoft.com/keys/microsoft.asc"
{{- if .work }}
apt_repository "zoom" "https://mirror.mwt.me/zoom/deb" "any main" "amd64" "https://mirror.mwt.me/zoom/gpgkey"
{{- end }}

# Development
packagelist "autoconf" "build-essential" "libtool" "pkg-config"
package "code"
packagelist "docker-ce" "docker-ce-cli" "golang-docker-credential-helpers"
package "gh"
packagelist "git" "git-crypt" "git-lfs"
package "helm"
{{ if .work -}}
package "jfrog-cli-v2"
{{ end -}}
package "kubectl"
package "openssh-client"
packagelist "packer" "terraform"
{{ if .personal -}}
package "rpi-imager"
{{ end -}}
package "task"
package "tmux"
package "vim"
package "xclip"

# Hardware
{{ if eq (output "cat" "/sys/devices/virtual/dmi/id/sys_vendor" | trim) "Dell Inc." -}}
# OEM metapackages
# See https://people.canonical.com/~oem-enablement/oem-meta-packages/datatables.html.
{{ if eq (output "cat" "/sys/devices/virtual/dmi/id/product_name" | trim) "Precision 5680" -}}
package "oem-somerville-muk-meta"

{{ end -}}

{{ if eq (output "cat" "/sys/devices/virtual/dmi/id/product_name" | trim) "Precision 5680" -}}
# Fixes for IPU6 cameras. See https://wiki.ubuntu.com/IntelMIPICamera
# and https://www.mathiashove.com/blog/2026/getting-ipu6-camera-working-on-ubuntu.
packagelist "linux-modules-ipu6-oem-{{ .chezmoi.osRelease.versionID }}"
packagelist "gstreamer1.0-icamera" "v4l-utils" "v4l2-relayd" "v4l2loopback-dkms"

{{ end -}}
{{ end -}}

# Miscellaneous
packagelist "libcairo2-dev" "libgirepository-2.0-dev" # build dependencies for `pygobject`

# Networking
{{ if .personal -}}
packagelist "cifs-utils" "nfs-common" "smbclient"
{{ end -}}
package "nmap"
package "speedtest-cli"
package "tcpdump"
{{ if .work -}}
package "teleport"
{{ end -}}
package "traceroute"
package "whois"

# Programming
package "golang-go"
packagelist "python3" "python3-argcomplete" "python3-pip" "python3-virtualenv" "pipx"

# Utility
{{ if .work -}}
package "1password"
{{ end -}}
package "bat"
package "curl"
{{ if .personal -}}
package "dropbox"
{{ end -}}
package "fd-find"
package "fzf"
package_from_url "google-chrome-stable" "https://dl.google.com/linux/direct/google-chrome-stable_current_amd64.deb"
packagelist "gnome-shell-extensions" "gnome-tweaks"
package "htop"
package "jq"
package "meld"
package "ncdu"
package_from_url "session-manager-plugin" "https://s3.amazonaws.com/session-manager-downloads/plugin/latest/ubuntu_64bit/session-manager-plugin.deb"
package "parallel"
package "pass"
{{ if .work -}}
packagelist "remmina" "remmina-plugin-vnc"
{{ end -}}
package "rename"
package "retry"
{{ if .work -}}
package "slack-desktop"
{{ end -}}
package "tree"
{{ if .personal -}}
package "vlc"
{{ end -}}
package "wget"
packagelist "yubikey-manager" "yubikey-manager-qt" "pamu2fcfg"
{{ if .work -}}
package "zoom"
{{ end -}}
package "zoxide"
