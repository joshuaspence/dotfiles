#!/bin/bash

set -o errexit
set -o nounset
set -o pipefail

{{-
  $extensions := list
-}}

{{- if .work -}}
{{-
  $extensions = concat $extensions (list
    "github.com/github/gh-es"
  )
-}}
{{- end -}}

{{- if $extensions }}
{{ range $extensions }}
gh extension install {{ . }}
{{- end }}
{{- end }}
