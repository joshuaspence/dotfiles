{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "awsAuthRefresh": "aws sso login --sso-session anduril-govcom",
  "env": {
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "au.anthropic.claude-haiku-4-5-20251001-v1:0",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "au.anthropic.claude-sonnet-4-5-20250929-v1:0",
    "ANTHROPIC_MODEL": "au.anthropic.claude-opus-4-6-v1[1m]",
    "AWS_PROFILE": "claude",
    "AWS_REGION": "ap-southeast-2",
    "CLAUDE_CODE_USE_BEDROCK": "1",
    "DISABLE_AUTOUPDATER": "1",
    "DISABLE_BUG_COMMAND": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_TELEMETRY": "1"
  },
  "permissions": {
    "allow": [
      "Read(~/workspace)"
    ],
    "ask": [],
    "deny": [
      "Read(/.env)",
      "Read(/.env.*)"
    ]
  },
  "sandbox": {
    "enabled": true
  },
  "skipWebFetchPreflight": true
}
